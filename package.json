{
  "name": "ucn-discord-bot",
  "type": "module",
  "main": "src/index.ts",
  "version": "1.0.0",
  "scripts": {
    "check": "tsc --noEmit && echo ✔ Ok",
    "build": "tsc",
    "dev": "bun --env-file=.env ./src/index.ts",
    "dev:dev": "bun --env-file=.env.dev ./src/index.ts",
    "watch": "bun --watch --env-file=.env ./src/index.ts",
    "watch:dev": "bun --watch --env-file=.env.dev ./src/index.ts",
    "start": "bun --env-file=.env .",
    "start:dev": "bun --env-file=.env.dev .",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bun --env-file=.env ./src/database/index.ts",
    "db:push": "bunx drizzle-kit push",
    "db:studio": "bunx drizzle-kit studio",
    "db:check": "bunx drizzle-kit check",
    "db:drop": "bunx drizzle-kit drop"
  },
  "dependencies": {
    "@constatic/base": "latest",
    "@magicyan/discord": "1.7.3",
    "chalk": "5.6.2",
    "discord-api-types": "^0.38.47",
    "discord.js": "14.26.2",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "zod": "4.1.11"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "drizzle-kit": "^0.31.10",
    "typescript": "5.7.2"
  },
  "imports": {
    "#env": [
      "./build/env.js"
    ],
    "#config": [
      "./build/config.js"
    ],
    "#base": [
      "./build/discord/index.js"
    ],
    "#functions": [
      "./build/functions/index.js"
    ],
    "#database": [
      "./build/database/index.js"
    ],
    "#schemas": [
      "./build/database/schema/index.js"
    ],
    "#queries": [
      "./build/database/queries/index.js"
    ],
    "#server": [
      "./build/server/index.js"
    ],
    "#menus": [
      "./build/menus/index.js"
    ],
    "#tools": [
      "./build/tools/index.js"
    ],
    "#lib/*": [
      "./build/lib/*"
    ],
    "#shared/*": [
      "./build/shared/*"
    ]
  },
  "baseVersion": "1.5.7"
}
